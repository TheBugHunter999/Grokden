{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:event:allow-unlisten",
    "opener:default",
    "dialog:default",
    "allow-list-folder",
    "allow-read-file",
    "allow-save-file",
    "allow-path-exists",
    "allow-create-file",
    "allow-create-folder",
    "allow-grok-cli-available",
    "allow-terminal-spawn",
    "allow-terminal-write",
    "allow-terminal-resize",
    "allow-terminal-close"
  ]
}