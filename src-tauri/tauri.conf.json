{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Grokden",
  "version": "0.3.3",
  "identifier": "com.grokden.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Grokden",
        "width": 1080,
        "height": 720,
        "minWidth": 1080,
        "minHeight": 680,
        "visible": true,
        "maximized": false,
        "center": true,
        "transparent": true,
        "decorations": false,
        "shadow": true,
        "resizable": true,
        "dragDropEnabled": false,
        "backgroundColor": "#00000000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Grokden",
    "shortDescription": "Desktop workspace for Grok CLI",
    "longDescription": "Grokden is a desktop application that combines a code editor, integrated terminals, and parallel Grok agent sessions in one workspace. Install Grok CLI separately before use.",
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": false,
        "template": "windows/nsis/installer.nsi"
      },
      "wix": {
        "language": "en-US",
        "template": "windows/main.wxs"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVBMUE2NEE1RENDRkVDRDQKUldUVTdNL2NwV1FhNnVRV0h4ZFRJOFZxQnBWa2pOS2hnRTJUZUJIRmZsdjV5YTIwM3pjR05Rc1gK",
      "endpoints": [
        "https://github.com/TheBugHunter999/Grokden/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
